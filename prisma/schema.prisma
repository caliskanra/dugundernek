datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  projects      WeddingProject[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model WeddingProject {
  id             String   @id @default(cuid())
  userId         String
  brideName      String
  groomName      String
  welcomeMessage String
  mediaUrl       String? // Optional welcome video/photo
  slug           String   @unique // The unique hostname.com.tr/bride&groomDDMMYYYY
  isGiftEnabled  Boolean  @default(true)
  venueAddress   String   @default("Belirtilmedi")
  weddingDate    DateTime?
  createdAt      DateTime @default(now())

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages GuestMessage[]
  gifts    Gift[]
}

model GuestMessage {
  id           String   @id @default(cuid())
  projectId    String
  guestName    String
  guestUserId  String?  // Google Auth user id
  guestEmail   String?  // Google Auth email
  message      String
  mediaUrl     String?  // Optional uploaded photo/video
  status       String   @default("pending") // pending, approved, rejected
  createdAt    DateTime @default(now())

  project WeddingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Gift {
  id          String   @id @default(cuid())
  projectId   String
  type        String   // gold, bracelet, money, wish
  subtype     String?  // çeyrek, yarım, tam
  quantity    Int      @default(1)
  currency    String?  // TRY, USD, EUR
  amount      Float?
  message     String?
  value       Float    // Equivalent value in TRY at time of gift
  senderName  String
  senderUserId String? // Google Auth user id
  senderEmail  String? // Google Auth email
  paymentToken String?   @unique // iyzico session token
  paymentId    String?   // iyzico unique payment id
  status       String   @default("pending") // pending, paid, failed, confirmed
  createdAt    DateTime @default(now())

  project WeddingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// 5651 Sayılı Kanun Uyumlu Yasal Log
model LegalLog {
  id            String   @id @default(cuid())
  action        String   // POST_MESSAGE, POST_GIFT, LOGIN
  userId        String?  // Google Auth user id
  userName      String?
  userEmail     String?
  ipAddress     String?
  userAgent     String?
  projectId     String?
  originalContent String? // Filtrelenmemiş orijinal içerik
  filteredContent String? // Filtreden geçmiş içerik
  hadProfanity  Boolean  @default(false)
  resourceId    String?  // GuestMessage or Gift id
  resourceType  String?  // message, gift
  metadata      String?  // JSON string for extra data
  createdAt     DateTime @default(now())
}
